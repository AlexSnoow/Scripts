      <ExcludeTodayFiles>true</ExcludeTodayFiles>
      <SourceFilter>*.*</SourceFilter>
      <ExcludeFilePattern></ExcludeFilePattern>
	  <!-- не могу понять как настроить удаление файлов которые попали в архив
