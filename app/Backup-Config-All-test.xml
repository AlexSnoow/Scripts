      <LocalDest>D:\testBackupsLocal\JOB4\</LocalDest>
      <LocalDestDaysOld>7</LocalDestDaysOld>
      <LocalDestKeepCount>7</LocalDestKeepCount>
      <RemoteDest>D:\testBackupsRemote\JOB4\</RemoteDest>
      <ArhLog>true</ArhLog>
    </Job>

	<!-- ========================================================================================== -->
    <!-- JOB51: Индивидуальная архивация файлов по маске jzdo.log.20			      				-->
	<!-- Если архив создался успешно удаление файлов из Источника которые попали в архив			-->
	<!-- НЕЛЬЗЯ УДАЛЯТЬ: Файлы jzdo.log, файлы не попали в архив					-->
