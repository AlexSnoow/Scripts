<?xml version="1.0" encoding="utf-8"?>
<!--
  hosts.xml — инвентарь серверов и заданий для Backup_PowerShell
  Используется: Backup-Manager.ps1 (GUI мониторинга)

  Структура:
    LogPathRoot — путь к сетевому хранилищу логов и отчётов
    Server — сервер с заданиями
      name — имя хоста
      ip — IP-адрес
      Task — задание на сервере
        id — имя задания (JOB1-JOB21)
        version — версия скрипта
-->
<BackupInventory>
    <!-- Путь к логам и XML-отчётам (тестовый, позже заменить на \\server\...) -->
    <LogPathRoot>C:\Work\BackupAllJson\logs</LogPathRoot>

    <!-- ============================================================ -->
    <!-- HOST1: Сервер приложений (JOB1-JOB5)                         -->
    <!-- Стандартная архивация с масками и без                        -->
    <!-- ============================================================ -->
    <Server name="host1" ip="10.0.1.1">
        <Task id="JOB1" version="2.5"/> <!-- Архивация с 15 масками, проверка масок -->
        <Task id="JOB2" version="2.5"/> <!-- Архивация с 2 масками (IBI, IIA) -->
        <Task id="JOB3" version="2.5"/> <!-- Стандартная архивация -->
        <Task id="JOB4" version="2.5"/> <!-- Стандартная архивация -->
        <Task id="JOB5" version="2.5"/> <!-- Стандартная архивация -->
    </Server>

    <!-- ============================================================ -->
    <!-- HOST2: Сервер данных (JOB6-JOB15)                            -->
    <!-- Индивидуальная архивация каталогов и файлов                  -->
    <!-- ============================================================ -->
    <Server name="host2" ip="10.0.1.2">
        <Task id="JOB6" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB7" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB8" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB9" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB10" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB11" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB12" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB13" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB14" version="2.5"/> <!-- Файлы fxserver.20*.log -->
        <Task id="JOB15" version="2.5"/> <!-- Файлы fxserver.20*.log -->
    </Server>

    <!-- ============================================================ -->
    <!-- HOST3: Сервер отчётов (JOB16-JOB20)                          -->
    <!-- Индивидуальная архивация каталогов и файлов                  -->
    <!-- ============================================================ -->
    <Server name="host3" ip="10.0.1.3">
        <Task id="JOB16" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB17" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB18" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB19" version="2.5"/> <!-- Каталоги, кроме сегодня -->
        <Task id="JOB20" version="2.5"/> <!-- Файлы fxserver.20*.log -->
    </Server>

    <!-- ============================================================ -->
    <!-- HOST4: Сервер логов (JOB21)                                  -->
    <!-- Индивидуальная архивация файлов info.log                     -->
    <!-- ============================================================ -->
    <Server name="host4" ip="10.0.1.4">
        <Task id="JOB21" version="2.5"/> <!-- Файлы info.log.20* -->
    </Server>
</BackupInventory>
