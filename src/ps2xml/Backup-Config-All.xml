      <Param>a</Param>
      <Param>-t7z</Param>
      <Param>-m0=lzma2</Param>
      <Param>-mx=5</Param>
      <Param>-mfb=64</Param>
      <Param>-md=32m</Param>
      <Param>-ms=on</Param>
      <Param>-sdel</Param>
      <Param>-r</Param>
