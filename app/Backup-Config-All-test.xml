    <Job Name="JOB4">
      <Source>C:\WORK\BackupAllXml\src\JOB4\</Source>
  	  <!-- <ArhParameters> -->
		   <!-- <Param>a</Param> -->
		   <!-- <Param>-m0</Param> -->
		   <!-- <Param>-ep1</Param> -->
		   <!-- <Param>-t</Param> -->
		   <!-- <Param>-rr1p</Param> -->
	  <!-- </ArhParameters> -->
